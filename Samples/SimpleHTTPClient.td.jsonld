{
  "@context": [
    "https://www.w3.org/2022/wot/td/v1.1"
  ],
  "id": "urn:http-sensor-01",
  "securityDefinitions": {
    "nosec_sc": {
      "scheme": "nosec"
    }
  },
  "security": [
    "nosec_sc"
  ],
  "@type": [
    "Thing"
  ],
  "name": "http-sensor-01",
  "base": "http://ipecho.net/",
  "title": "HTTP REST Sensor",
  "properties": {
    "IPAddress": {
      "type": "string",
      "readOnly": true,
      "observable": true,
      "forms": [
        {
          "href": "/plain",
          "op": [
            "readproperty",
            "observeproperty"
          ],
          "type": "xsd:string",
          "pollingTime": 100000
        }
      ]
    }
  }
}
