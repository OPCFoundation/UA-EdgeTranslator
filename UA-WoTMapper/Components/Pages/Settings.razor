@page "/settings"
@using WotOpcUaMapper.Models
@using WotOpcUaMapper.Services
@inject SettingsService SettingsSvc

<PageTitle>Settings</PageTitle>

<h1>UA Cloud Library Settings</h1>

<p class="hint">Configure the UA Cloud Library endpoint and credentials used to list and download nodesets. Changes are saved automatically and kept for your session (they survive a page refresh).</p>

<EditForm Model="_settings" class="settings-form">
    <label>
        Cloud Library URL
        <InputText @bind-Value="_settings.CloudLibraryUrl" @bind-Value:after="PersistAsync" placeholder="https://uacloudlibrary.opcfoundation.org" />
    </label>
    <label>
        User name
        <InputText @bind-Value="_settings.UserName" @bind-Value:after="PersistAsync" autocomplete="username" />
    </label>
    <label>
        Password
        <InputText type="password" @bind-Value="_settings.Password" @bind-Value:after="PersistAsync" autocomplete="current-password" />
    </label>
</EditForm>

@code {
    private AppSettings _settings = new();

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender)
        {
            await SettingsSvc.HydrateAsync();
            _settings = SettingsSvc.Current;
            StateHasChanged();
        }
    }

    private async Task PersistAsync()
    {
        await SettingsSvc.SaveAsync(_settings);
    }
}
