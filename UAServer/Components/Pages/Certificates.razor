@page "/certificates"
@inject DiagnosticsService Diagnostics
@implements IDisposable

<PageHeader Title="Certificates" Subtitle="OPC UA application certificate & trust lists" OnRefresh="Reload" />

@if (_data is null)
{
    <div class="loading">Loading…</div>
}
else
{
    @if (_data.ProvisioningMode)
    {
        @if (_data.IgnoreProvisioningMode)
        {
            <div class="banner banner-warning">
                <strong>Provisioning mode ignored</strong> — no issuer certificates are present, but <span class="mono">IGNORE_PROVISIONING_MODE</span> is set, so untrusted client certificates are <strong>rejected</strong>. Use the <strong>Trust</strong> button below to move a rejected certificate into the trusted store.
            </div>
        }
        else
        {
            <div class="banner banner-warning">
                <strong>Provisioning mode</strong> — no issuer certificates are present, so untrusted client certificates are auto-accepted until a GDS pushes a trust list.
            </div>
        }
    }

    <div class="stat-grid">
        <div class="stat"><span class="stat-label">Application</span><span class="stat-value">@_data.ApplicationCertificates.Count</span></div>
        <div class="stat"><span class="stat-label">Trusted peers</span><span class="stat-value">@_data.TrustedCount</span></div>
        <div class="stat"><span class="stat-label">Issuers</span><span class="stat-value">@_data.IssuerCount</span></div>
        <div class="stat"><span class="stat-label">Rejected</span><span class="stat-value">@_data.RejectedCount</span></div>
    </div>

    <h2 class="section-title">Application certificate</h2>
    @if (_data.ApplicationCertificates.Count == 0)
    {
        <div class="card"><div class="card-body"><p class="muted">No application certificate found in <span class="mono">@_data.OwnStorePath</span>.</p></div></div>
    }
    else
    {
        <div class="card-grid">
            @foreach (var cert in _data.ApplicationCertificates)
            {
                <div class="card">
                    <div class="card-header">
                        <h3 class="card-title">@CommonName(cert.Subject)</h3>
                        <StatusPill Status="@cert.Status" />
                    </div>
                    <div class="card-body">
                        <div class="kv-table">
                            <div class="kv-row"><span class="kv-key">Subject</span><span class="kv-value mono">@cert.Subject</span></div>
                            <div class="kv-row"><span class="kv-key">Issuer</span><span class="kv-value mono">@cert.Issuer</span></div>
                            <div class="kv-row"><span class="kv-key">Valid from</span><span class="kv-value">@(cert.NotBefore.ToString("yyyy-MM-dd"))</span></div>
                            <div class="kv-row"><span class="kv-key">Valid to</span><span class="kv-value">@(cert.NotAfter.ToString("yyyy-MM-dd")) <span class="muted">(@ExpiryText(cert))</span></span></div>
                            <div class="kv-row"><span class="kv-key">Algorithm</span><span class="kv-value">@cert.SignatureAlgorithm</span></div>
                            <div class="kv-row"><span class="kv-key">Key size</span><span class="kv-value">@cert.KeySize bit</span></div>
                            <div class="kv-row"><span class="kv-key">Serial</span><span class="kv-value mono">@cert.SerialNumber</span></div>
                            <div class="kv-row"><span class="kv-key">Thumbprint</span><span class="kv-value mono">@cert.Thumbprint</span></div>
                        </div>
                        <div class="card-actions">
                            <a class="btn-trust" href="@($"certificates/download/{cert.Thumbprint}")" download="@cert.FileName" title="Download the public OPC UA certificate">Download certificate</a>
                        </div>
                    </div>
                </div>
            }
        </div>
    }

    <h2 class="section-title">Trusted peer certificates</h2>
    @if (!string.IsNullOrEmpty(_message) && _messageForTrusted)
    {
        <div class="banner @(_messageSuccess ? "banner-success" : "banner-warning")">@_message</div>
    }
    @if (_data.TrustedCount == 0)
    {
        <div class="card"><div class="card-body"><p class="muted">No trusted peer certificates in <span class="mono">@_data.TrustedStorePath</span>.</p></div></div>
    }
    else
    {
        <div class="card table-card">
            <table class="data-table">
                <thead><tr><th>Subject</th><th>Issuer</th><th>Expires</th><th>Status</th><th></th></tr></thead>
                <tbody>
                    @foreach (var cert in _data.TrustedCertificates)
                    {
                        <tr>
                            <td class="mono">@CommonName(cert.Subject)</td>
                            <td class="mono">@CommonName(cert.Issuer)</td>
                            <td>@(cert.NotAfter.ToString("yyyy-MM-dd"))</td>
                            <td><StatusPill Status="@cert.Status" /></td>
                            <td class="table-action">
                                <button type="button" class="btn-danger" disabled="@_busy" @onclick="() => Untrust(cert)" title="Delete this certificate from the trusted store">Delete</button>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
            @if (_data.TrustedCertificates.Count < _data.TrustedCount)
            {
                <p class="muted table-note">Showing @_data.TrustedCertificates.Count of @_data.TrustedCount certificates.</p>
            }
        </div>
    }

    <h2 class="section-title">Issuer certificates</h2>
    @if (_data.IssuerCount == 0)
    {
        <div class="card"><div class="card-body"><p class="muted">No issuer certificates in <span class="mono">@_data.IssuerStorePath</span>.</p></div></div>
    }
    else
    {
        <div class="card table-card">
            <table class="data-table">
                <thead><tr><th>Subject</th><th>Issuer</th><th>Expires</th><th>Status</th></tr></thead>
                <tbody>
                    @foreach (var cert in _data.IssuerCertificates)
                    {
                        <tr>
                            <td class="mono">@CommonName(cert.Subject)</td>
                            <td class="mono">@CommonName(cert.Issuer)</td>
                            <td>@(cert.NotAfter.ToString("yyyy-MM-dd"))</td>
                            <td><StatusPill Status="@cert.Status" /></td>
                        </tr>
                    }
                </tbody>
            </table>
            @if (_data.IssuerCertificates.Count < _data.IssuerCount)
            {
                <p class="muted table-note">Showing @_data.IssuerCertificates.Count of @_data.IssuerCount certificates.</p>
            }
        </div>
    }

    <h2 class="section-title">Rejected certificates</h2>
    @if (!string.IsNullOrEmpty(_message) && !_messageForTrusted)
    {
        <div class="banner @(_messageSuccess ? "banner-success" : "banner-warning")">@_message</div>
    }
    @if (_data.RejectedCount == 0)
    {
        <div class="card"><div class="card-body"><p class="muted">No rejected certificates in <span class="mono">@_data.RejectedStorePath</span>.</p></div></div>
    }
    else
    {
        <div class="card table-card">
            <table class="data-table">
                <thead><tr><th>Subject</th><th>Issuer</th><th>Expires</th><th>Status</th><th></th></tr></thead>
                <tbody>
                    @foreach (var cert in _data.RejectedCertificates)
                    {
                        <tr>
                            <td class="mono">@CommonName(cert.Subject)</td>
                            <td class="mono">@CommonName(cert.Issuer)</td>
                            <td>@(cert.NotAfter.ToString("yyyy-MM-dd"))</td>
                            <td><StatusPill Status="@cert.Status" /></td>
                            <td class="table-action">
                                <button type="button" class="btn-trust" disabled="@_busy" @onclick="() => Trust(cert)" title="Move this certificate to the trusted store">Trust</button>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
            @if (_data.RejectedCertificates.Count < _data.RejectedCount)
            {
                <p class="muted table-note">Showing @_data.RejectedCertificates.Count of @_data.RejectedCount certificates.</p>
            }
        </div>
    }
}

@code {
    private CertificateOverview _data;
    private bool _busy;
    private string _message;
    private bool _messageSuccess;
    private bool _messageForTrusted;
    private PeriodicTimer _timer;

    protected override void OnInitialized()
    {
        Reload();
        _timer = new PeriodicTimer(TimeSpan.FromSeconds(5));
        _ = RefreshLoopAsync();
    }

    private async Task RefreshLoopAsync()
    {
        try
        {
            while (await _timer.WaitForNextTickAsync())
            {
                Reload();
                await InvokeAsync(StateHasChanged);
            }
        }
        catch (ObjectDisposedException)
        {
            // The component was disposed between ticks; stop refreshing.
        }
    }

    public void Dispose() => _timer?.Dispose();

    private void Reload() => _data = Diagnostics.GetCertificateOverview();

    private void Trust(CertificateInfo cert)
    {
        _busy = true;
        try
        {
            TrustCertificateResult result = Diagnostics.TrustRejectedCertificate(cert.Thumbprint);
            _message = result.Message;
            _messageSuccess = result.Success;
            _messageForTrusted = false;
        }
        finally
        {
            _busy = false;
            Reload();
        }
    }

    private void Untrust(CertificateInfo cert)
    {
        _busy = true;
        try
        {
            TrustCertificateResult result = Diagnostics.UntrustCertificate(cert.Thumbprint);
            _message = result.Message;
            _messageSuccess = result.Success;
            _messageForTrusted = true;
        }
        finally
        {
            _busy = false;
            Reload();
        }
    }

    private static string CommonName(string subject)
    {
        if (string.IsNullOrEmpty(subject))
        {
            return subject;
        }

        foreach (var part in subject.Split(','))
        {
            string trimmed = part.Trim();
            if (trimmed.StartsWith("CN=", StringComparison.OrdinalIgnoreCase))
            {
                return trimmed[3..];
            }
        }

        return subject;
    }

    private static string ExpiryText(CertificateInfo cert)
        => cert.DaysUntilExpiry < 0
            ? $"expired {-cert.DaysUntilExpiry} days ago"
            : $"in {cert.DaysUntilExpiry} days";
}
