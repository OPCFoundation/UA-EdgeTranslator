# Repo-root .dockerignore. Used by both UAServer/Dockerfile and
# ProtocolDrivers/Dockerfile.driverpack, which both build with the repo root as
# the Docker context so they can see Directory.Packages.props /
# Directory.Build.props / global.json (required by NuGet central package
# management).
**/.classpath
**/.dockerignore
**/.env
**/.git
**/.github
**/.gitignore
**/.project
**/.settings
**/.toolstarget
**/.vs
**/.vscode
**/*.*proj.user
**/*.dbmdl
**/*.jfm
**/azds.yaml
**/bin
**/charts
**/docker-compose*
**/node_modules
**/npm-debug.log
**/obj
**/secrets.dev.yaml
**/values.dev.yaml
LICENSE
README.md
SECURITY.md
CONTRIBUTING.md
