@page "/"
@rendermode InteractiveServer
@using System.Text.Json
@using WotOpcUaMapper.Components.Shared
@using WotOpcUaMapper.Models
@using WotOpcUaMapper.Services
@using WotOpcUaMapper.UAClientLib
@inject UAClient UaClient
@inject CloudLibraryClient CloudLib
@inject IJSRuntime JS
@implements IAsyncDisposable

<PageTitle>WoT &harr; OPC UA Mapper</PageTitle>

<div class="mapper-layout">

    <!-- LEFT PANE: WoT Thing Model properties -->
    <section class="pane pane-left">
        <div class="pane-header">
            <h2>WoT Thing Model</h2>
            <label class="btn btn-file">
                Open Thing Model&hellip;
                <InputFile OnChange="OnThingModelSelected" accept=".jsonld,.json,.tm.jsonld" hidden />
            </label>
            @if (_thingModel != null)
            {
                <button class="btn" @onclick="DownloadThingModel">Save mapped model</button>
            }
        </div>

        @if (_thingModel == null)
        {
            <p class="hint">Load a Web of Things Thing Model (<code>.tm.jsonld</code>) file to list its properties.</p>
        }
        else
        {
            <div class="tm-title">@_thingModel.Title <small>(@_thingModel.Properties.Count properties)</small></div>
            <div class="prop-list">
                @foreach (var prop in _thingModel.Properties)
                {
                    <div class="prop-card @(prop.IsMapped ? "mapped" : "") @(_dropTarget == prop ? "drop-hover" : "")"
                         ondragover="event.preventDefault();"
                         @ondragenter="() => _dropTarget = prop"
                         @ondragleave="() => _dropTarget = null"
                         @ondrop="() => OnDropOnProperty(prop)">
                        <div class="prop-name">@prop.Name <span class="prop-type">@prop.Type</span></div>
                        @if (!string.IsNullOrEmpty(prop.Description))
                        {
                            <div class="prop-desc">@prop.Description</div>
                        }
                        @if (prop.IsMapped)
                        {
                            <div class="prop-map">
                                <div><b>NodeId:</b> @prop.MapToNodeId</div>
                                <div><b>Type:</b> @prop.MapToType</div>
                                @if (!string.IsNullOrEmpty(prop.MapByFieldPath))
                                {
                                    <div><b>Field path:</b> @prop.MapByFieldPath</div>
                                }
                                <button class="btn btn-xs" @onclick="() => ClearMapping(prop)">Remove mapping</button>
                            </div>
                        }
                        else
                        {
                            <div class="prop-drophint">Drop an OPC UA type here to map</div>
                        }
                    </div>
                }
            </div>
        }
    </section>

    <!-- RIGHT PANE: OPC UA nodeset browser -->
    <section class="pane pane-right">
        <div class="pane-header">
            <h2>OPC UA Nodeset</h2>
            <label class="btn btn-file">
                Open NodeSet2 XML&hellip;
                <InputFile OnChange="OnNodesetFileSelected" accept=".xml" hidden />
            </label>
            <select class="cloud-select" @onchange="OnCloudNodesetSelected">
                <option value="">-- Cloud Library nodeset --</option>
                @foreach (var ns in _cloudNodesets)
                {
                    <option value="@ns.Identifier">@ns.Title</option>
                }
            </select>
            <button class="btn" @onclick="RefreshCloudNodesets">Refresh list</button>
        </div>

        @if (_loadingNodeset)
        {
            <p class="hint">Loading nodeset and dependencies&hellip;</p>
        }

        @if (!string.IsNullOrEmpty(_nodesetError))
        {
            <p class="error">@_nodesetError</p>
        }

        @if (_loadedNamespaces.Count > 0)
        {
            <details class="ns-status">
                <summary>Loaded namespaces (@_loadedNamespaces.Count)@(_missingNamespaces.Count > 0 ? $" — {_missingNamespaces.Count} missing" : "")</summary>
                <ul>
                    @foreach (var ns in _loadedNamespaces)
                    {
                        <li>@ns.Key <small>(v@ns.Value.Item2)</small></li>
                    }
                    @foreach (var miss in _missingNamespaces)
                    {
                        <li class="missing">@miss (missing)</li>
                    }
                </ul>
            </details>
        }

        @if (_treeNodes.Count > 0)
        {
            <div class="tree-container">
                <Tree Nodes="_treeNodes" TNode="NodesetViewerNode"
                      ChildSelector="node => node.Children"
                      SelectedNode="_selectedNode"
                      SelectedNodeChanged="SelectedNodeChanged"
                      OnNodeExpand="OnNodeExpand"
                      HasChildNodes="HasChildNodes">
                    <TitleTemplate>
                        <span draggable="true"
                              @ondragstart="() => OnDragStart(context)"
                              class="ua-node ua-node-@context.NodeClass.ToLowerInvariant()">
                            @context.Text
                        </span>
                    </TitleTemplate>
                </Tree>
            </div>
        }
        else if (!_loadingNodeset)
        {
            <p class="hint">Open a NodeSet2 XML file or pick a nodeset from the UA Cloud Library to browse OPC UA types. Drag a type onto a WoT property to map it.</p>
        }
    </section>
</div>

<!-- Complex-type field path picker dialog -->
@if (_showFieldDialog && _pendingMapping != null)
{
    <div class="modal-backdrop-custom" @onclick="CancelFieldDialog">
        <div class="modal-card" @onclick:stopPropagation="true">
            <h3>Select field path</h3>
            <p>
                The OPC UA type <b>@_pendingMapping.DisplayName</b> is a complex type.
                Select which field of the type maps to WoT property <b>@_pendingProperty?.Name</b>.
            </p>
            <div class="field-list">
                @foreach (var field in _pendingMapping.Fields)
                {
                    <label class="field-option">
                        <input type="radio" name="fieldpath" value="@field.Path"
                               checked="@(_selectedFieldPath == field.Path)"
                               @onchange="() => _selectedFieldPath = field.Path" />
                        <span>@field.Name</span>
                        <small>@field.DataType</small>
                    </label>
                }
            </div>
            <div class="modal-actions">
                <button class="btn" @onclick="ConfirmFieldDialog" disabled="@string.IsNullOrEmpty(_selectedFieldPath)">Map</button>
                <button class="btn btn-secondary" @onclick="CancelFieldDialog">Cancel</button>
            </div>
        </div>
    </div>
}

@code {
    private ThingModel? _thingModel;

    private readonly List<NodesetViewerNode> _treeNodes = new();
    private NodesetViewerNode? _selectedNode;
    private NodesetViewerNode? _draggedNode;
    private WotProperty? _dropTarget;

    private List<CloudLibNodeset> _cloudNodesets = new();
    private bool _loadingNodeset;
    private string? _nodesetError;
    private string? _loadedNamespaceUri;

    private Dictionary<string, Tuple<string, string>> _loadedNamespaces = new();
    private List<string> _missingNamespaces = new();

    // complex-type dialog state
    private bool _showFieldDialog;
    private NodeMappingInfo? _pendingMapping;
    private WotProperty? _pendingProperty;
    private string? _selectedFieldPath;

    protected override async Task OnInitializedAsync()
    {
        await RefreshCloudNodesets();
    }

    // ---------- WoT Thing Model ----------

    private async Task OnThingModelSelected(InputFileChangeEventArgs e)
    {
        try
        {
            using var reader = new StreamReader(e.File.OpenReadStream(20 * 1024 * 1024));
            var json = await reader.ReadToEndAsync();
            _thingModel = ThingModel.Parse(json);
            _thingModel.FileName = e.File.Name;
        }
        catch (Exception ex)
        {
            _nodesetError = "Failed to parse Thing Model: " + ex.Message;
        }
    }

    private void ClearMapping(WotProperty prop)
    {
        prop.ClearMapping();
    }

    private async Task DownloadThingModel()
    {
        if (_thingModel == null)
        {
            return;
        }

        var json = _thingModel.Serialize();
        var fileName = _thingModel.FileName ?? "thingmodel.tm.jsonld";
        await JS.InvokeVoidAsync("downloadText", fileName, json);
    }

    // ---------- OPC UA nodeset ----------

    private async Task RefreshCloudNodesets()
    {
        try
        {
            _cloudNodesets = await CloudLib.GetNamespacesAsync();
        }
        catch (Exception ex)
        {
            _nodesetError = "Failed to query Cloud Library: " + ex.Message;
        }
    }

    private async Task OnNodesetFileSelected(InputFileChangeEventArgs e)
    {
        try
        {
            using var reader = new StreamReader(e.File.OpenReadStream(50 * 1024 * 1024));
            var xml = await reader.ReadToEndAsync();
            await LoadNodesetXml(xml);
        }
        catch (Exception ex)
        {
            _nodesetError = "Failed to read nodeset file: " + ex.Message;
        }
    }

    private async Task OnCloudNodesetSelected(ChangeEventArgs e)
    {
        var identifier = e.Value?.ToString();
        if (string.IsNullOrEmpty(identifier))
        {
            return;
        }

        _loadingNodeset = true;
        _nodesetError = null;
        StateHasChanged();

        try
        {
            var xml = await CloudLib.DownloadNodesetXmlAsync(identifier);
            if (string.IsNullOrEmpty(xml))
            {
                _nodesetError = "Could not download the selected nodeset from the Cloud Library.";
                return;
            }
            await LoadNodesetXml(xml);
        }
        catch (Exception ex)
        {
            _nodesetError = "Failed to load Cloud Library nodeset: " + ex.Message;
        }
        finally
        {
            _loadingNodeset = false;
        }
    }

    private async Task LoadNodesetXml(string xml)
    {
        _loadingNodeset = true;
        _nodesetError = null;
        _treeNodes.Clear();
        StateHasChanged();

        try
        {
            await UaClient.LoadNodesetAsync(xml, ResolveDependencyAsync);

            _loadedNamespaces = UaClient.LoadedNamespaces;
            _missingNamespaces = UaClient.MissingNamespaces;
            _loadedNamespaceUri = _loadedNamespaces.Keys.LastOrDefault();

            var root = new NodesetViewerNode
            {
                Id = ObjectIdsRoot,
                Text = "Root",
                Children = new List<NodesetViewerNode>()
            };
            _treeNodes.Add(root);
            _selectedNode = root;
            await OnNodeExpand(root);
        }
        catch (Exception ex)
        {
            _nodesetError = "Failed to load nodeset: " + ex.Message;
        }
        finally
        {
            _loadingNodeset = false;
        }
    }

    private const string ObjectIdsRoot = "i=84"; // ObjectIds.RootFolder

    private async Task<string?> ResolveDependencyAsync(string namespaceUri)
    {
        var identifier = await CloudLib.FindIdentifierByNamespaceAsync(namespaceUri);
        if (string.IsNullOrEmpty(identifier))
        {
            return null;
        }
        return await CloudLib.DownloadNodesetXmlAsync(identifier);
    }

    private async Task OnNodeExpand(NodesetViewerNode node)
    {
        if (node.Children.Count == 0)
        {
            var children = await UaClient.GetChildren(node.Id, true);
            if (children != null)
            {
                children.Sort();
                node.Children = children;
            }
        }
    }

    private async Task SelectedNodeChanged(NodesetViewerNode node)
    {
        _selectedNode = node;
        await Task.CompletedTask;
    }

    private bool HasChildNodes(NodesetViewerNode node) => node.Children != null;

    // ---------- Drag & drop mapping ----------

    private void OnDragStart(NodesetViewerNode node)
    {
        _draggedNode = node;
    }

    private async Task OnDropOnProperty(WotProperty prop)
    {
        _dropTarget = null;
        if (_draggedNode == null)
        {
            return;
        }

        var mapping = await UaClient.GetNodeMappingAsync(_draggedNode.Id);
        _draggedNode = null;

        if (mapping == null)
        {
            _nodesetError = "Could not resolve mapping information for the dragged node.";
            return;
        }

        if (mapping.IsComplex && mapping.Fields.Count > 0)
        {
            // ask the user which field path to map
            _pendingMapping = mapping;
            _pendingProperty = prop;
            _selectedFieldPath = null;
            _showFieldDialog = true;
            return;
        }

        ApplyMapping(prop, mapping, null);
    }

    private void ApplyMapping(WotProperty prop, NodeMappingInfo mapping, string? fieldPath)
    {
        prop.ApplyMapping(mapping.NodeId, mapping.TypeNodeId, fieldPath);
        if (_thingModel != null && !string.IsNullOrEmpty(_loadedNamespaceUri))
        {
            _thingModel.EnsureContextPrefix("uav", ExtractNamespace(mapping.TypeNodeId) ?? _loadedNamespaceUri);
        }
    }

    private static string? ExtractNamespace(string typeNodeId)
    {
        // typeNodeId like "nsu=http://...;i=3005"
        const string key = "nsu=";
        var idx = typeNodeId.IndexOf(key, StringComparison.Ordinal);
        if (idx < 0)
        {
            return null;
        }
        var rest = typeNodeId[(idx + key.Length)..];
        var end = rest.IndexOf(';');
        return end >= 0 ? rest[..end] : rest;
    }

    private void ConfirmFieldDialog()
    {
        if (_pendingMapping != null && _pendingProperty != null)
        {
            ApplyMapping(_pendingProperty, _pendingMapping, _selectedFieldPath);
        }
        CancelFieldDialog();
    }

    private void CancelFieldDialog()
    {
        _showFieldDialog = false;
        _pendingMapping = null;
        _pendingProperty = null;
        _selectedFieldPath = null;
    }

    public async ValueTask DisposeAsync()
    {
        await UaClient.DisposeAsync();
    }
}

