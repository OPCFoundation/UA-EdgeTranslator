  "name": "opcda-matrikon-simulation",
  "base": "opc.da://localhost/Matrikon.OPC.Simulation.1",
  "title": "Matrikon OPC DA Simulation Server",
  "description": "Sample OPC DA Thing Description for Matrikon OPC Simulation Server. OPC DA is a legacy Windows-only protocol that uses COM/DCOM for communication.",
  "properties": {
