      "type": "integer",
      "readOnly": true,
      "observable": true,
      "forms": [
        {
          "href": "Random.Int1",
          "op": [
            "readproperty",
            "observeproperty"
          ],
          "type": "xsd:int",
          "pollingTime": 1000
        }
      ]
    },
